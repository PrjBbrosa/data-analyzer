{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/scripts/lessons/select.py\" --hook",
            "timeout": 10,
            "statusMessage": "Selecting relevant lessons"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/scripts/lessons/check.py\" --post-tool-hook",
            "timeout": 10,
            "statusMessage": "Recording lesson signals"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/scripts/lessons/check.py\" --hook",
            "timeout": 30,
            "statusMessage": "Checking lessons gate"
          }
        ]
      }
    ]
  }
}
